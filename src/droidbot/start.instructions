    if opts.apk_path and opts.apk_file_path:
        print("Provide only one of -a or -aa.")
        return

    if opts.apk_file_path:
        if not os.path.exists(opts.apk_file_path):
            print(f"apk_file_path does not exist. {opts.apk_file_path}")
            return

        with open(opts.apk_file_path) as f:
            opts.apk_path = f.read().strip()
            opts.apk_path = os.path.expandvars(opts.apk_path)
